{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build FLOW",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-O3",
                "-mwindows",
                "-Wall",
                "-Wextra",
                "-I${workspaceFolder}/include",
                "-o",
                "${workspaceFolder}/build/FLOW.exe",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/FlowEngine.cpp",
                "-luser32",
                "-lgdi32",
                "-lcomctl32",
                "-static-libgcc",
                "-static-libstdc++"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build and Run FLOW",
            "type": "shell",
            "dependsOn": "Build FLOW",
            "command": "powershell",
            "args": [
                "-Command",
                "Start-Process",
                "-FilePath",
                "'${workspaceFolder}/build/FLOW.exe'"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
